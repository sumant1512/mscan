    {
      "_id": "req_dlr_001",
      "colId": "col_mscan_verifyapp",
      "containerId": "fol_dealer_auth",
      "url": "{{baseUrl}}/api/mobile/v1/auth/dealer/request-otp",
      "name": "1. Dealer Request OTP",
      "method": "POST",
      "sortNum": 10000,
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"phone_e164\": \"{{dealerPhone}}\"\n}"
      },
      "notes": "Phone must be in E.164 format: +919876543210 (include + and country code). Dealer must be pre-registered by tenant admin."
    },
    {
      "_id": "req_dlr_002",
      "colId": "col_mscan_verifyapp",
      "containerId": "fol_dealer_auth",
      "url": "{{baseUrl}}/api/mobile/v1/auth/dealer/verify-otp",
      "name": "2. Dealer Verify OTP — get token",
      "method": "POST",
      "sortNum": 20000,
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"phone_e164\": \"{{dealerPhone}}\",\n  \"otp\": \"123456\"\n}"
      },
      "notes": "Copy accessToken → {{dealerToken}}. Then use X-App-Id header on all dealer mobile endpoints to select which verification app context to use."
    },
    {
      "_id": "req_dlr_003",
      "colId": "col_mscan_verifyapp",
      "containerId": "fol_dealer_auth",
      "url": "{{baseUrl}}/api/mobile/v1/auth/refresh",
