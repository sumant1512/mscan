        { "name": "Authorization", "value": "Bearer {{customerToken}}" },
        { "name": "X-App-Id", "value": "{{appId}}" },
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"coupon_code\": \"COUPON001\"\n}"
      },
      "notes": "Same endpoint, same payload — just swap the Bearer token to a customer JWT from /auth/verify-otp"
