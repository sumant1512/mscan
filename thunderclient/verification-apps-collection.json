      "_id": "req_adm_001",
      "colId": "col_mscan_verifyapp",
      "containerId": "fol_admin_auth",
      "url": "{{baseUrl}}/api/auth/request-otp",
      "name": "1. Request OTP",
      "method": "POST",
      "sortNum": 10000,
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"{{adminEmail}}\"\n}"
      }
    },
    {
      "_id": "req_adm_002",
      "colId": "col_mscan_verifyapp",
      "containerId": "fol_admin_auth",
      "url": "{{baseUrl}}/api/auth/verify-otp",
      "name": "2. Verify OTP — get token",
