      "sortNum": 20000,
      "headers": [
        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"otp\": \"123456\"\n}"
      },
      "notes": "Copy accessToken → {{token}}, refreshToken → {{refreshToken}}"
    },
    {
      "_id": "req_adm_003",
      "colId": "col_mscan_verifyapp",
      "containerId": "fol_admin_auth",
