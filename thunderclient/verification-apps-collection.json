        { "name": "Content-Type", "value": "application/json" }
      ],
      "params": [],
      "body": {
        "type": "json",
        "raw": "{\n  \"coupon_code\": \"COUPON001\"\n}"
      },
      "notes": "Works for both DEALER and CUSTOMER JWTs. Use dealerToken or customerToken in Authorization. X-App-Id must be the verification app UUID. DEALER: marks coupon used and awards dealer points. CUSTOMER: records scan and awards customer credits."
    },
    {
      "_id": "req_scan_002",
      "colId": "col_mscan_verifyapp",
      "containerId": "fol_scan",
      "url": "{{baseUrl}}/api/mobile/v1/scan",
